---
/**
 * <About> — expertise narrative + image cluster.
 *
 * Left: a clustered image arrangement (one large anchor image plus two
 * smaller offset images and a circular "Contact us" badge).
 * Right: eyebrow, accented headline, body, checkmark bullets, CTA.
 */
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Heading from '../ui/Heading.astro';
import Text from '../ui/Text.astro';
import Button from '../ui/Button.astro';
import Image from '../ui/Image.astro';
import Icon from '../ui/Icon.astro';
import AccentText from '../ui/AccentText.astro';
import { FadeIn } from '../motion/FadeIn';

interface Props {
  eyebrow: string;
  headline: string;
  accent: string;
  body: string;
  bullets: string[];
  ctaLabel: string;
  ctaHref: string;
  images: {
    main: string;
    secondary: string;
    tertiary: string;
  };
}

const { eyebrow, headline, accent, body, bullets, ctaLabel, ctaHref, images } = Astro.props;
---

<Section tone="light" padding="default" id="about" aria-labelledby="about-heading">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      {/* Image cluster */}
      <FadeIn client:load>
        <div class="relative">
          <div class="grid grid-cols-5 grid-rows-6 gap-3 md:gap-4 aspect-[5/6] max-w-lg mx-auto">
            <div class="col-span-3 row-span-6">
              <Image
                src={images.main}
                alt="Smiling patient with dentist"
                width={600}
                height={800}
                rounded="2xl"
                aspect="aspect-[3/4] h-full"
              />
            </div>
            <div class="col-span-2 row-span-3 col-start-4">
              <Image
                src={images.secondary}
                alt="Modern dental clinic interior"
                width={400}
                height={300}
                rounded="2xl"
                aspect="aspect-[4/3] h-full"
              />
            </div>
            <div class="col-span-2 row-span-3 col-start-4">
              <Image
                src={images.tertiary}
                alt="Dental tools laid out"
                width={400}
                height={300}
                rounded="2xl"
                aspect="aspect-[4/3] h-full"
              />
            </div>
          </div>

          {/* Floating "Contact us" badge */}
          <a
            href={ctaHref}
            class="absolute -bottom-6 -left-2 md:bottom-4 md:-left-8 w-28 h-28 md:w-32 md:h-32 rounded-full bg-dark text-dark-fg grid place-items-center text-center shadow-lg transition-transform duration-base ease-out-quint hover:rotate-6 hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
            aria-label="Contact us"
          >
            <span class="flex flex-col items-center gap-1.5">
              <Icon name="arrow-up-right" size={20} class="text-accent" />
              <span class="text-xs font-medium tracking-wide leading-tight">Contact<br />us</span>
            </span>
          </a>
        </div>
      </FadeIn>

      {/* Content */}
      <FadeIn client:load delay={0.1}>
        <div class="space-y-7">
          <Text size="sm" tone="accent" weight="medium" class="uppercase tracking-widest">{eyebrow}</Text>
          <Heading id="about-heading" as="h2" size="display-lg">
            <AccentText text={headline} accent={accent} />
          </Heading>
          <Text size="lg" tone="muted">{body}</Text>

          <ul class="space-y-3 pt-2">
            {bullets.map((bullet) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 w-6 h-6 rounded-full bg-accent-soft text-accent grid place-items-center shrink-0" aria-hidden="true">
                  <Icon name="check" size={14} strokeWidth={2.5} />
                </span>
                <Text size="base" weight="medium">{bullet}</Text>
              </li>
            ))}
          </ul>

          <div class="pt-3">
            <Button variant="primary" size="lg" href={ctaHref}>{ctaLabel}</Button>
          </div>
        </div>
      </FadeIn>
    </div>
  </Container>
</Section>
