---
/**
 * <Footer> — site footer.
 *
 * 4-column grid on desktop: brand + tagline + social | services | quick links | contact.
 * Thin divider + copyright row below. Dark tone, reduced padding.
 */
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Heading from '../ui/Heading.astro';
import Text from '../ui/Text.astro';
import Icon from '../ui/Icon.astro';

interface LinkItem {
  label: string;
  href: string;
}

interface Props {
  brand: string;
  tagline: string;
  servicesLinks: LinkItem[];
  quickLinks: LinkItem[];
  contact: {
    address: string;
    phone: string;
    email: string;
  };
  social?: {
    instagram?: string;
    facebook?: string;
  };
  copyrightSuffix?: string;
}

const {
  brand,
  tagline,
  servicesLinks,
  quickLinks,
  contact,
  social,
  copyrightSuffix = 'Designed by Milvow',
} = Astro.props;

const year = new Date().getFullYear();

const linkClasses =
  'text-sm text-dark-fg/70 hover:text-dark-fg transition-colors duration-fast ease-out-quint focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-dark rounded-sm';
---

<Section tone="dark" padding="sm" as="footer" aria-label="Site footer">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      {/* Brand */}
      <div class="space-y-5 lg:col-span-1">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-dark-fg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent rounded-full"
          aria-label={`${brand} — home`}
        >
          <span class="inline-grid place-items-center w-9 h-9 rounded-full bg-accent text-accent-fg text-sm font-bold">N</span>
          <Heading as="span" size="xl" tone="inherit" class="text-dark-fg">{brand}</Heading>
        </a>
        <Text size="sm" class="text-dark-fg/70 max-w-xs">{tagline}</Text>
        {social && (
          <div class="flex items-center gap-3 pt-1">
            {social.instagram && (
              <a
                href={social.instagram}
                aria-label="Instagram"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 grid place-items-center rounded-full border border-dark-fg/20 text-dark-fg hover:border-dark-fg hover:bg-dark-fg/10 transition-colors duration-fast ease-out-quint focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
              >
                <Icon name="instagram" size={18} />
              </a>
            )}
            {social.facebook && (
              <a
                href={social.facebook}
                aria-label="Facebook"
                target="_blank"
                rel="noopener noreferrer"
                class="w-10 h-10 grid place-items-center rounded-full border border-dark-fg/20 text-dark-fg hover:border-dark-fg hover:bg-dark-fg/10 transition-colors duration-fast ease-out-quint focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
              >
                <Icon name="facebook" size={18} />
              </a>
            )}
          </div>
        )}
      </div>

      {/* Services */}
      <div class="space-y-4">
        <Text size="sm" weight="semibold" class="text-dark-fg uppercase tracking-widest">Services</Text>
        <ul class="space-y-2.5">
          {servicesLinks.map((l) => (
            <li><a href={l.href} class={linkClasses}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      {/* Quick links */}
      <div class="space-y-4">
        <Text size="sm" weight="semibold" class="text-dark-fg uppercase tracking-widest">Quick Links</Text>
        <ul class="space-y-2.5">
          {quickLinks.map((l) => (
            <li><a href={l.href} class={linkClasses}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      {/* Contact */}
      <div class="space-y-4">
        <Text size="sm" weight="semibold" class="text-dark-fg uppercase tracking-widest">Contact</Text>
        <ul class="space-y-3 text-sm text-dark-fg/70">
          <li class="flex items-start gap-3">
            <Icon name="map-pin" size={18} class="text-dark-fg mt-0.5" />
            <span>{contact.address}</span>
          </li>
          <li>
            <a href={`tel:${contact.phone.replace(/[^+\d]/g, '')}`} class={`${linkClasses} flex items-center gap-3`}>
              <Icon name="phone" size={18} class="text-dark-fg" />
              <span>{contact.phone}</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${contact.email}`} class={`${linkClasses} flex items-center gap-3`}>
              <Icon name="mail" size={18} class="text-dark-fg" />
              <span>{contact.email}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-6 border-t border-dark-fg/15 flex flex-col sm:flex-row gap-2 items-start sm:items-center justify-between">
      <Text size="xs" class="text-dark-fg/60">© {year} {brand}. All rights reserved.</Text>
      <Text size="xs" class="text-dark-fg/60">{copyrightSuffix}</Text>
    </div>
  </Container>
</Section>
