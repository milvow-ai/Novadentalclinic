---
/**
 * <CaseStories> — dark-tone case study gallery.
 *
 * Eyebrow + accented headline on the left (accent-soft for visibility on
 * dark bg). Onward CTA top-right using the secondary `onDark` variant.
 * Below: a flexible grid of large image cards, each with a year badge,
 * treatment tag chips, and a title overlay. shadow-lg gives them a
 * floating feel against the navy background.
 */
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Heading from '../ui/Heading.astro';
import Text from '../ui/Text.astro';
import Button from '../ui/Button.astro';
import Image from '../ui/Image.astro';
import AccentText from '../ui/AccentText.astro';
import { FadeIn } from '../motion/FadeIn';

interface CaseItem {
  year: string;
  title: string;
  tags: string[];
  image: string;
  href?: string;
}

interface Props {
  eyebrow: string;
  headline: string;
  accent: string;
  ctaLabel: string;
  ctaHref: string;
  items: CaseItem[];
}

const { eyebrow, headline, accent, ctaLabel, ctaHref, items } = Astro.props;
---

<Section tone="dark" padding="default" id="case-stories" aria-labelledby="case-stories-heading">
  <Container>
    <FadeIn client:load>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14">
        <div class="space-y-4 max-w-2xl">
          <Text size="sm" weight="medium" class="uppercase tracking-widest text-accent">{eyebrow}</Text>
          <Heading id="case-stories-heading" as="h2" size="display-lg" tone="inherit" class="text-dark-fg">
            <AccentText
              text={headline}
              accent={accent}
              accentClass="text-accent-soft"
            />
          </Heading>
        </div>
        <div class="shrink-0">
          <Button variant="secondary" size="md" onDark href={ctaHref}>{ctaLabel}</Button>
        </div>
      </div>
    </FadeIn>

    <FadeIn client:load delay={0.1}>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
        {items.map((item) => (
          <a
            href={item.href ?? '#case-stories'}
            class="group relative block rounded-2xl overflow-hidden bg-bg shadow-lg transition-transform duration-base ease-out-quint hover:-translate-y-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-dark"
            aria-label={`Case story: ${item.title}`}
          >
            <div class="relative">
              <Image
                src={item.image}
                alt={item.title}
                width={1200}
                height={900}
                rounded="none"
                aspect="aspect-[4/3]"
              />
              <span class="absolute top-4 left-4 rounded-full bg-bg/90 backdrop-blur-sm text-fg text-xs font-mono font-semibold px-3 py-1.5">
                {item.year}
              </span>
              <div class="absolute inset-0 bg-gradient-to-t from-dark/85 via-dark/20 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6 md:p-7 space-y-3">
                <div class="flex flex-wrap gap-2">
                  {item.tags.map((tag) => (
                    <span class="inline-flex items-center rounded-full bg-dark-fg/15 backdrop-blur-sm text-dark-fg text-xs font-medium px-3 py-1 border border-dark-fg/20">
                      {tag}
                    </span>
                  ))}
                </div>
                <Heading as="h3" size="2xl" tone="inherit" class="text-dark-fg">{item.title}</Heading>
              </div>
            </div>
          </a>
        ))}
      </div>
    </FadeIn>
  </Container>
</Section>
