---
/**
 * <Services> — grid of image-top service cards.
 *
 * Header row: eyebrow + accented headline (left) and primary CTA (right).
 * Below: 3-col grid (desktop) of image-top cards. Each card carries a
 * rounded blue icon overlay on the bottom-left of its image.
 */
import Section from '../ui/Section.astro';
import Container from '../ui/Container.astro';
import Heading from '../ui/Heading.astro';
import Text from '../ui/Text.astro';
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import Image from '../ui/Image.astro';
import Icon from '../ui/Icon.astro';
import type { IconName } from '../ui/icon-names';
import AccentText from '../ui/AccentText.astro';
import { FadeIn } from '../motion/FadeIn';

interface ServiceItem {
  name: string;
  description: string;
  image: string;
  icon: IconName;
  href?: string;
}

interface Props {
  eyebrow: string;
  headline: string;
  accent: string;
  ctaLabel: string;
  ctaHref: string;
  items: ServiceItem[];
}

const { eyebrow, headline, accent, ctaLabel, ctaHref, items } = Astro.props;
---

<Section tone="subtle" padding="default" id="services" aria-labelledby="services-heading">
  <Container>
    <FadeIn client:load>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14">
        <div class="space-y-4 max-w-2xl">
          <Text size="sm" tone="accent" weight="medium" class="uppercase tracking-widest">{eyebrow}</Text>
          <Heading id="services-heading" as="h2" size="display-lg">
            <AccentText text={headline} accent={accent} />
          </Heading>
        </div>
        <div class="shrink-0">
          <Button variant="primary" size="md" href={ctaHref}>{ctaLabel}</Button>
        </div>
      </div>
    </FadeIn>

    <FadeIn client:load delay={0.1}>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {items.map((item) => (
          <Card variant="image-top" interactive href={item.href ?? '#services'} class="bg-bg">
            <div class="relative">
              <Image
                src={item.image}
                alt={item.name}
                width={800}
                height={600}
                rounded="none"
                aspect="aspect-[4/3]"
              />
              <span
                class="absolute bottom-4 left-4 w-12 h-12 rounded-full bg-accent text-accent-fg grid place-items-center shadow-glow"
                aria-hidden="true"
              >
                <Icon name={item.icon} size={22} strokeWidth={1.75} />
              </span>
            </div>
            <div class="p-6 md:p-7 space-y-3">
              <Heading as="h3" size="xl">{item.name}</Heading>
              <Text size="sm" tone="muted">{item.description}</Text>
              <div class="flex items-center gap-1.5 pt-2 text-sm font-medium text-accent">
                <span>Learn more</span>
                <Icon name="arrow-right" size={16} class="transition-transform duration-fast ease-out-quint group-hover:translate-x-0.5" />
              </div>
            </div>
          </Card>
        ))}
      </div>
    </FadeIn>
  </Container>
</Section>
