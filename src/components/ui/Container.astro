---
/**
 * <Container> — single source of truth for horizontal layout.
 *
 * max-width: 1280px (via `max-w-container` custom utility).
 * Padding scales: px-6 (mobile) -> px-8 (md) -> px-12 (lg).
 *
 * NEVER hand-roll a max-w + px combo on a page. Always use this.
 */
import { cn } from '../../lib/cn';

interface Props {
  as?: 'div' | 'section' | 'article' | 'header' | 'footer' | 'main' | 'nav';
  class?: string;
  id?: string;
}

const { as: Tag = 'div', class: className, ...rest } = Astro.props;

const classes = cn(
  'max-w-container mx-auto px-6 md:px-8 lg:px-12',
  className,
);
---

<Tag class={classes} {...rest}>
  <slot />
</Tag>
