---
/**
 * <Icon> — inline SVG icon primitive.
 *
 * Uses lucide-style stroke paths (viewBox 0 0 24 24, currentColor stroke).
 * Rendered as inline SVG so it streams with the HTML — zero runtime cost,
 * no font, no external bundle. `currentColor` inherits parent text color.
 *
 * To add a new icon: append a `name` to the union and a `{name === ... &&}`
 * block to the dispatch below.
 */
import { cn } from '../../lib/cn';
import type { IconName } from './icon-names';

interface Props {
  name: IconName;
  class?: string;
  size?: number;
  strokeWidth?: number;
  label?: string;
}

const {
  name,
  class: className,
  size = 20,
  strokeWidth = 2,
  label,
} = Astro.props;

const classes = cn('inline-block shrink-0', className);
const ariaHidden = !label;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={classes}
  aria-hidden={ariaHidden ? 'true' : undefined}
  role={!ariaHidden ? 'img' : undefined}
  aria-label={label}
>
  {name === 'check' && <polyline points="20 6 9 17 4 12" />}
  {name === 'play' && <polygon points="6 3 20 12 6 21 6 3" fill="currentColor" stroke="none" />}
  {name === 'phone' && (
    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
  )}
  {name === 'mail' && (
    <Fragment>
      <rect x="2" y="4" width="20" height="16" rx="2" />
      <path d="m22 7-10 5L2 7" />
    </Fragment>
  )}
  {name === 'map-pin' && (
    <Fragment>
      <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z" />
      <circle cx="12" cy="10" r="3" />
    </Fragment>
  )}
  {name === 'arrow-right' && (
    <Fragment>
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </Fragment>
  )}
  {name === 'arrow-up-right' && (
    <Fragment>
      <line x1="7" y1="17" x2="17" y2="7" />
      <polyline points="7 7 17 7 17 17" />
    </Fragment>
  )}
  {name === 'menu' && (
    <Fragment>
      <line x1="4" y1="6" x2="20" y2="6" />
      <line x1="4" y1="12" x2="20" y2="12" />
      <line x1="4" y1="18" x2="20" y2="18" />
    </Fragment>
  )}
  {name === 'x' && (
    <Fragment>
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </Fragment>
  )}
  {name === 'instagram' && (
    <Fragment>
      <rect x="2" y="2" width="20" height="20" rx="5" />
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
      <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none" />
    </Fragment>
  )}
  {name === 'facebook' && (
    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
  )}
  {name === 'chevron-right' && <polyline points="9 18 15 12 9 6" />}
  {name === 'sparkles' && (
    <path d="M12 3l1.9 5.7L20 11l-6.1 1.9L12 19l-1.9-6.1L4 11l6.1-2.3L12 3z" />
  )}
  {name === 'tooth' && (
    <path d="M12 2C8.13 2 5 4.42 5 8.5c0 2.04.62 3.36 1.18 4.78.31.79.62 1.58.82 2.47.36 1.61.7 4.25 1.5 5.25.79.99 1.55.5 2-.5.5-1.1.5-3 1.5-3s1 1.9 1.5 3c.45 1 1.21 1.49 2 .5.8-1 1.14-3.64 1.5-5.25.2-.89.51-1.68.82-2.47.56-1.42 1.18-2.74 1.18-4.78C19 4.42 15.87 2 12 2z" />
  )}
  {name === 'shield-check' && (
    <Fragment>
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      <path d="m9 12 2 2 4-4" />
    </Fragment>
  )}
  {name === 'heart-pulse' && (
    <Fragment>
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
      <path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27" />
    </Fragment>
  )}
  {name === 'smile' && (
    <Fragment>
      <circle cx="12" cy="12" r="10" />
      <path d="M8 14s1.5 2 4 2 4-2 4-2" />
      <line x1="9" y1="9" x2="9.01" y2="9" />
      <line x1="15" y1="9" x2="15.01" y2="9" />
    </Fragment>
  )}
  {name === 'sun-medium' && (
    <Fragment>
      <circle cx="12" cy="12" r="4" />
      <path d="M12 3v1M12 20v1M3 12h1M20 12h1M5.6 5.6l.7.7M17.7 17.7l.7.7M5.6 18.4l.7-.7M17.7 6.3l.7-.7" />
    </Fragment>
  )}
  {name === 'baby' && (
    <Fragment>
      <path d="M9 12h.01M15 12h.01M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5" />
      <path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3" />
    </Fragment>
  )}
  {name === 'calendar' && (
    <Fragment>
      <rect x="3" y="4" width="18" height="18" rx="2" />
      <line x1="16" y1="2" x2="16" y2="6" />
      <line x1="8" y1="2" x2="8" y2="6" />
      <line x1="3" y1="10" x2="21" y2="10" />
    </Fragment>
  )}
  {name === 'clock' && (
    <Fragment>
      <circle cx="12" cy="12" r="10" />
      <polyline points="12 6 12 12 16 14" />
    </Fragment>
  )}
  {name === 'user' && (
    <Fragment>
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
      <circle cx="12" cy="7" r="4" />
    </Fragment>
  )}
  {name === 'stethoscope' && (
    <Fragment>
      <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3" />
      <path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4" />
      <circle cx="20" cy="10" r="2" />
    </Fragment>
  )}
</svg>
