---
/**
 * <Input> — form input primitive.
 *
 * Renders a labeled <input> (or <select>/<textarea>) with consistent token
 * styling, focus-visible accent ring, and required-marker handling.
 *
 * Pass `as="select"` for a dropdown; children become <option>s.
 * Pass `as="textarea"` for multi-line input.
 */
import { cn } from '../../lib/cn';

type As = 'input' | 'select' | 'textarea';
type InputType = 'text' | 'email' | 'tel' | 'date' | 'time' | 'number' | 'url';

interface Props {
  as?: As;
  type?: InputType;
  name: string;
  id?: string;
  label?: string;
  placeholder?: string;
  required?: boolean;
  value?: string;
  rows?: number;
  autocomplete?: string;
  class?: string;
}

const {
  as = 'input',
  type = 'text',
  name,
  id = name,
  label,
  placeholder,
  required = false,
  value,
  rows = 4,
  autocomplete,
  class: className,
} = Astro.props;

const fieldClasses = cn(
  'w-full rounded-md border border-border bg-bg text-fg',
  'px-4 py-3 text-base font-normal',
  'placeholder:text-muted',
  'transition-[border-color,box-shadow] duration-fast ease-out-quint',
  'hover:border-fg/40',
  'focus-visible:outline-none focus-visible:border-accent focus-visible:ring-2 focus-visible:ring-accent/30',
  'disabled:opacity-50 disabled:cursor-not-allowed',
  as === 'select' && 'appearance-none pr-10 bg-[url("data:image/svg+xml,%3Csvg%20xmlns=%27http://www.w3.org/2000/svg%27%20width=%2712%27%20height=%2712%27%20viewBox=%270%200%2024%2024%27%20fill=%27none%27%20stroke=%27%236B7280%27%20stroke-width=%272%27%20stroke-linecap=%27round%27%20stroke-linejoin=%27round%27%3E%3Cpolyline%20points=%276%209%2012%2015%2018%209%27/%3E%3C/svg%3E")] bg-no-repeat bg-[right_1rem_center]',
  className,
);
---

<div class="flex flex-col gap-2">
  {label && (
    <label for={id} class="text-sm font-medium text-fg">
      {label}
      {required && (
        <span class="text-accent ml-0.5" aria-hidden="true">*</span>
      )}
    </label>
  )}

  {as === 'input' && (
    <input
      type={type}
      id={id}
      name={name}
      placeholder={placeholder}
      required={required}
      value={value}
      autocomplete={autocomplete}
      class={fieldClasses}
      aria-required={required ? 'true' : undefined}
    />
  )}

  {as === 'select' && (
    <select
      id={id}
      name={name}
      required={required}
      class={fieldClasses}
      aria-required={required ? 'true' : undefined}
    >
      <slot />
    </select>
  )}

  {as === 'textarea' && (
    <textarea
      id={id}
      name={name}
      rows={rows}
      placeholder={placeholder}
      required={required}
      class={fieldClasses}
      aria-required={required ? 'true' : undefined}
    >{value}</textarea>
  )}
</div>
